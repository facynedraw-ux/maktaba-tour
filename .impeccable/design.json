      { "name": "La Règle du Neutre Teinté",   "body": "Aucun gris pur. Chaque neutre penche vers le mauve ou le rose. #888888 est interdit.",                  "section": "colors" },
      { "name": "La Règle du Serif Réservé",   "body": "Playfair Display uniquement dans h1–h3, logo, pull quotes. Jamais dans les boutons ni le corps de texte.", "section": "typography" },
      { "name": "La Règle du Plat-par-Défaut", "body": "Surfaces sans ombre au repos. L'ombre rose apparaît au hover uniquement.",                               "section": "elevation" }
